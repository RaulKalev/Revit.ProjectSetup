<Window
    x:Class="ProjectSetup.UI.CreatePlanSetsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:ProjectSetup.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Plaanide Loomine"
    Width="560"
    Height="520"
    MinWidth="420"
    MinHeight="360"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ui:BoolToVisibilityConverter         x:Key="BoolToVisibilityConverter"/>
            <ui:InverseBoolToVisibilityConverter  x:Key="InverseBoolToVisibilityConverter"/>

            <!-- Category group card style -->
            <Style x:Key="GroupCardStyle" TargetType="Border">
                <Setter Property="Background"    Value="{DynamicResource SecondaryBackgroundBrush}"/>
                <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"  Value="6"/>
                <Setter Property="Margin"        Value="0,0,0,8"/>
            </Style>

            <!-- Group header button -->
            <Style x:Key="GroupHeaderButtonStyle" TargetType="Button">
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"      Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" Padding="10,8">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#18FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Category checkbox style inherits from existing DatagridCheckboxStyle -->
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="#70babc"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Margin"      Value="2,0,0,10"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Glass chrome border -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2"/>
            </Border.Effect>
        </Border>

        <!-- Main content -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            ClipToBounds="True"
            CornerRadius="10">

            <Grid PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>   <!-- Title bar -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                    <RowDefinition Height="28"/>   <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <ui:TitleBar
                    Grid.Row="0"
                    IsMinimizeVisible="False"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded"/>

                <!-- Content -->
                <Grid Grid.Row="1" Margin="14,10,14,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header label -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>     <!-- Scroll area -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>  <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Style="{StaticResource SectionHeaderStyle}"
                               Text="VALI PLAANIDE KATEGOORIAD"/>

                    <!-- Scrollable category cards -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- ═══ EL Group ═══ -->
                            <Border Style="{StaticResource GroupCardStyle}">
                                <StackPanel>
                                    <!-- EL Header -->
                                    <Button Style="{StaticResource GroupHeaderButtonStyle}"
                                            Command="{Binding ToggleELCommand}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="EL — Elektripaigaldis"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <materialDesign:PackIcon Grid.Column="1"
                                                Width="18" Height="18"
                                                Foreground="{DynamicResource IconForegroundBrush}"
                                                VerticalAlignment="Center">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Kind" Value="ChevronUp"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsELExpanded}" Value="False">
                                                                <Setter Property="Kind" Value="ChevronDown"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Grid>
                                    </Button>

                                    <!-- EL Items -->
                                    <ItemsControl
                                        ItemsSource="{Binding ELItems}"
                                        Visibility="{Binding IsELExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="10,4,10,10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox
                                                    IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Content="{Binding Name}"
                                                    Foreground="{DynamicResource ForegroundBrush}"
                                                    Margin="0,3"
                                                    FontSize="12"
                                                    Style="{StaticResource DatagridCheckboxStyle}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- ═══ EN Group ═══ -->
                            <Border Style="{StaticResource GroupCardStyle}">
                                <StackPanel>
                                    <!-- EN Header -->
                                    <Button Style="{StaticResource GroupHeaderButtonStyle}"
                                            Command="{Binding ToggleENCommand}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="EN — Nõrkvool"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <materialDesign:PackIcon Grid.Column="1"
                                                Width="18" Height="18"
                                                Foreground="{DynamicResource IconForegroundBrush}"
                                                VerticalAlignment="Center">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Kind" Value="ChevronUp"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsENExpanded}" Value="False">
                                                                <Setter Property="Kind" Value="ChevronDown"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Grid>
                                    </Button>

                                    <!-- EN Items -->
                                    <ItemsControl
                                        ItemsSource="{Binding ENItems}"
                                        Visibility="{Binding IsENExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="10,4,10,10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox
                                                    IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Content="{Binding Name}"
                                                    Foreground="{DynamicResource ForegroundBrush}"
                                                    Margin="0,3"
                                                    FontSize="12"
                                                    Style="{StaticResource DatagridCheckboxStyle}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Loading overlay -->
                    <Grid Grid.Row="2"
                          Visibility="{Binding IsCreating, Converter={StaticResource BoolToVisibilityConverter}}"
                          Background="#AA1F1F1F"
                          Panel.ZIndex="10">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar
                                IsIndeterminate="True"
                                Width="220" Height="4"
                                Foreground="#70babc"
                                Background="Transparent"
                                BorderThickness="0"/>
                            <TextBlock
                                Text="Plaanide loomine…"
                                HorizontalAlignment="Center"
                                Foreground="{DynamicResource ForegroundBrush}"
                                FontSize="13"
                                Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Action row -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1"
                                Content="{Binding CreateButtonLabel}"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Command="{Binding CreateCommand}"
                                Width="110" Height="32" FontSize="12"
                                Margin="0,0,6,0"/>
                        <Button Grid.Column="2"
                                Content="Cancel"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="80" Height="32" FontSize="12"
                                Margin="0"
                                Click="Cancel_Click"/>
                    </Grid>
                </Grid>

                <!-- Status bar -->
                <Border
                    Grid.Row="2"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="14,0">
                    <TextBlock
                        Text="{Binding StatusMessage}"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{DynamicResource IconForegroundBrush}"
                        TextTrimming="CharacterEllipsis"/>
                </Border>

            </Grid>
        </Border>

        <!-- Resize handles -->
        <Border x:Name="LeftEdge"          Width="5"  HorizontalAlignment="Left"   Margin="0,10,0,10" Background="Transparent" Cursor="SizeWE"    MouseEnter="LeftEdge_MouseEnter"          MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="LeftEdge_MouseLeftButtonDown"/>
        <Border x:Name="RightEdge"         Width="5"  HorizontalAlignment="Right"  Margin="0,10,0,10" Background="Transparent" Cursor="SizeWE"    MouseEnter="RightEdge_MouseEnter"         MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="RightEdge_MouseLeftButtonDown"/>
        <Border x:Name="BottomEdge"        Height="5" VerticalAlignment="Bottom"   Margin="10,0,10,0" Background="Transparent" Cursor="SizeNS"    MouseEnter="BottomEdge_MouseEnter"        MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomEdge_MouseLeftButtonDown"/>
        <Border x:Name="BottomLeftCorner"  Width="10" Height="10" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNESW" MouseEnter="BottomLeftCorner_MouseEnter"  MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomLeftCorner_MouseLeftButtonDown"/>
        <Border x:Name="BottomRightCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNWSE" MouseEnter="BottomRightCorner_MouseEnter" MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomRightCorner_MouseLeftButtonDown"/>
    </Grid>
</Window>
