<Window
    x:Class="ProjectSetup.UI.DialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:ProjectSetup.UI"
    xmlns:vm="clr-namespace:ProjectSetup.UI.ViewModels"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Dialog"
    SizeToContent="WidthAndHeight"
    MinWidth="340"
    MaxWidth="520"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    KeyDown="Window_KeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <ui:BoolToVisibilityConverter   x:Key="BoolToVisibilityConverter"/>
            <ui:NullToCollapsedConverter    x:Key="NullToCollapsedConverter"/>

            <!-- Default button style (ghost) -->
            <Style x:Key="DialogButtonStyle" TargetType="Button" BasedOn="{StaticResource CustomActionButtonStyle}">
                <Setter Property="Width"    Value="Auto"/>
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Height"   Value="30"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding"  Value="12,0"/>
                <Setter Property="Margin"   Value="6,0,0,0"/>
            </Style>

            <!-- Primary / accent button -->
            <Style x:Key="DialogButtonPrimaryStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
                <Setter Property="Background"   Value="#70babc"/>
                <Setter Property="Foreground"   Value="#1a1a1a"/>
                <Setter Property="BorderBrush"  Value="#70babc"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Glass chrome border -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2"/>
            </Border.Effect>
        </Border>

        <!-- Content -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            ClipToBounds="True"
            CornerRadius="10">

            <StackPanel Margin="24,20,24,20">

                <!-- Icon + Title row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon
                        x:Name="DialogIcon"
                        Width="22" Height="22"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Kind="{Binding IconKind}"
                        Foreground="{Binding IconColor}"
                        Visibility="{Binding IconKind, Converter={StaticResource NullToCollapsedConverter}}"/>
                    <TextBlock
                        Text="{Binding Title}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource ForegroundBrush}"
                        VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Message -->
                <TextBlock
                    Text="{Binding Message}"
                    FontSize="13"
                    Foreground="{DynamicResource ForegroundBrush}"
                    TextWrapping="Wrap"
                    MaxWidth="520"
                    Margin="0,0,0,10"/>

                <!-- Optional detail list (scrollable, max 5 rows tall) -->
                <Border
                    Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="5"
                    Margin="0,0,0,14"
                    MaxHeight="130">
                    <ScrollViewer
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Padding="10,6">
                        <ItemsControl ItemsSource="{Binding DetailItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding}"
                                        FontSize="12"
                                        Foreground="{DynamicResource IconForegroundBrush}"
                                        Padding="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Button row -->
                <ItemsControl
                    x:Name="ButtonsHost"
                    HorizontalAlignment="Right">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

            </StackPanel>
        </Border>
    </Grid>
</Window>
