<Window
    x:Class="ProjectSetup.UI.CopyElementsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:ProjectSetup.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Copy Families"
    Width="1000"
    Height="660"
    MinWidth="680"
    MinHeight="480"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ui:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <ui:NullToCollapsedConverter  x:Key="NullToCollapsedConverter"/>

            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#70babc"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="2,0,0,10"/>
            </Style>

            <Style x:Key="RowLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Glass chrome border -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2"/>
            </Border.Effect>
        </Border>

        <!-- Main content -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            ClipToBounds="True"
            CornerRadius="10">

            <Grid PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>   <!-- Title bar -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                    <RowDefinition Height="28"/>   <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- ── Title bar ──────────────────────────────── -->
                <ui:TitleBar
                    Grid.Row="0"
                    IsMinimizeVisible="False"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded"/>

                <!-- ── Content ────────────────────────────────── -->
                <Grid Grid.Row="1" Margin="14,10,14,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header -->
                        <RowDefinition Height="Auto"/>  <!-- Source project row -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>  <!-- Filter row -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>     <!-- DataGrid -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>  <!-- Action buttons -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0"
                               Style="{StaticResource SectionHeaderStyle}"
                               Text="COPY FAMILIES FROM PROJECT"/>

                    <!-- Source project -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource RowLabelStyle}" Text="Source Project:"/>
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{Binding SourceProjects}"
                            SelectedItem="{Binding SelectedProject}"
                            Style="{StaticResource DarkThemeComboBox}"
                            FontSize="13"
                            Height="32"/>
                        <Button
                            Grid.Column="2"
                            Content="Refresh"
                            Style="{StaticResource CustomActionButtonStyle}"
                            Command="{Binding RefreshProjectsCommand}"
                            Width="72" Height="32"
                            FontSize="12"
                            Margin="8,0,0,0"
                            ToolTip="Reload the list of open Revit documents"/>
                    </Grid>

                    <!-- Filter row: Category + Search -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource RowLabelStyle}" Text="Category:"/>

                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{Binding AllCategories}"
                            SelectedItem="{Binding SelectedCategory}"
                            Style="{StaticResource DarkThemeComboBox}"
                            FontSize="13"
                            Height="32"/>

                        <TextBlock Grid.Column="3" Style="{StaticResource RowLabelStyle}" Text="Search:"/>

                        <!-- Search box with overlaid clear button -->
                        <Grid Grid.Column="4">
                            <TextBox
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource CustomTextBoxStyle}"
                                Height="32"
                                FontSize="13"
                                Padding="5,0,26,0"
                                HorizontalAlignment="Stretch"/>

                            <!-- Circle-X clear button, overlaid on the right of the TextBox -->
                            <Button
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Width="16" Height="16"
                                Margin="0,0,6,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Focusable="False"
                                Panel.ZIndex="1"
                                Command="{Binding ClearSearchCommand}"
                                Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="Clear search">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse
                                                x:Name="Bg"
                                                Fill="Transparent"
                                                Stroke="{DynamicResource IconForegroundBrush}"
                                                StrokeThickness="1.3"/>
                                            <materialDesign:PackIcon
                                                Kind="Close"
                                                Width="9" Height="9"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource IconForegroundBrush}"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Stroke" Value="{DynamicResource ForegroundBrush}"/>
                                                <Setter TargetName="Bg" Property="Fill"   Value="#22ffffff"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>

                    <!-- DataGrid -->
                    <Border Grid.Row="5"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            ClipToBounds="True">
                        <DataGrid
                            x:Name="FamiliesGrid"
                            ItemsSource="{Binding FilteredItems}"
                            Background="{DynamicResource PrimaryBackgroundBrush}"
                            Style="{StaticResource CustomDataGridStyle}"
                            ColumnHeaderStyle="{StaticResource CustomDataGridColumnHeaderStyle}"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            IsReadOnly="False"
                            SelectionMode="Single"
                            SelectionUnit="FullRow"
                            AlternationCount="2"
                            RowHeaderWidth="0"
                            BorderThickness="0"
                            PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown">

                            <DataGrid.Columns>

                                <!-- Checkbox -->
                                <DataGridTemplateColumn
                                    Width="40"
                                    CanUserSort="False"
                                    CanUserResize="False">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                IsChecked="{Binding DataContext.AllSelected, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                IsThreeState="True"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource DatagridCheckboxStyle}"
                                                Foreground="#70babc"
                                                ToolTip="Select / deselect all visible families"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource DatagridCheckboxStyle}"
                                                Foreground="#70babc"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Category -->
                                <DataGridTextColumn
                                    Header="Category"
                                    Binding="{Binding Category}"
                                    Width="190"
                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="6,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource IconForegroundBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Family name -->
                                <DataGridTextColumn
                                    Header="Family Name"
                                    Binding="{Binding Name}"
                                    Width="*"
                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="6,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Type count -->
                                <DataGridTextColumn
                                    Header="Types"
                                    Binding="{Binding TypeCount}"
                                    Width="70"
                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="6,0"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource IconForegroundBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Loading overlay -->
                    <Grid Grid.Row="5"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                          Background="#AA1F1F1F"
                          Panel.ZIndex="10">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar
                                IsIndeterminate="True"
                                Width="220" Height="4"
                                Foreground="#70babc"
                                Background="Transparent"
                                BorderThickness="0"/>
                            <TextBlock
                                Text="Loading…"
                                HorizontalAlignment="Center"
                                Foreground="{DynamicResource ForegroundBrush}"
                                FontSize="13"
                                Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Action row -->
                    <Grid Grid.Row="7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Content="Select All"
                            Style="{StaticResource CustomActionButtonStyle}"
                            Command="{Binding SelectAllCommand}"
                            Width="90" Height="32"
                            FontSize="12"
                            Margin="0,0,6,0"/>
                        <Button
                            Grid.Column="1"
                            Content="Clear All"
                            Style="{StaticResource CustomActionButtonStyle}"
                            Command="{Binding DeselectAllCommand}"
                            Width="90" Height="32"
                            FontSize="12"/>
                        <Button
                            Grid.Column="3"
                            Content="{Binding ImportButtonLabel}"
                            Style="{StaticResource CustomActionButtonStyle}"
                            Command="{Binding ImportCommand}"
                            Width="150" Height="32"
                            FontSize="12"
                            ToolTip="Copy selected families into the active Revit document"/>
                    </Grid>
                </Grid>

                <!-- ── Status bar ──────────────────────────────── -->
                <Border
                    Grid.Row="2"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    CornerRadius="0,0,9,9"
                    Padding="12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding DisplayCount}"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0"/>
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding SelectedCount, StringFormat='Selected: {0}'}"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0"/>
                        <TextBlock
                            Grid.Column="2"
                            Text="{Binding StatusMessage}"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            FontSize="11"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
