<Window
    x:Class="ProjectSetup.UI.LinkDwgWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:ProjectSetup.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Link DWG Files"
    Width="820"
    Height="540"
    MinWidth="580"
    MinHeight="380"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ui:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#70babc"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="2,0,0,10"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Glass chrome border -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2"/>
            </Border.Effect>
        </Border>

        <!-- Main content -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            ClipToBounds="True"
            CornerRadius="10">

            <Grid PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>   <!-- Title bar -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                    <RowDefinition Height="28"/>   <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <ui:TitleBar
                    Grid.Row="0"
                    IsMinimizeVisible="False"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded"/>

                <!-- Content -->
                <Grid Grid.Row="1" Margin="14,10,14,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>     <!-- DataGrid -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>  <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Style="{StaticResource SectionHeaderStyle}"
                               Text="DWG FILES - VAADETE VASTAVUS"/>

                    <!-- DataGrid -->
                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            ClipToBounds="True">
                        <DataGrid
                            x:Name="DwgFilesGrid"
                            ItemsSource="{Binding Items}"
                            Background="{DynamicResource PrimaryBackgroundBrush}"
                            Style="{StaticResource CustomDataGridStyle}"
                            ColumnHeaderStyle="{StaticResource CustomDataGridColumnHeaderStyle}"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            IsReadOnly="False"
                            SelectionMode="Single"
                            SelectionUnit="FullRow"
                            AlternationCount="2"
                            RowHeaderWidth="0"
                            BorderThickness="0"
                            PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown">

                            <DataGrid.Columns>

                                <!-- Checkbox -->
                                <DataGridTemplateColumn Width="40" CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                IsChecked="{Binding DataContext.AllSelected, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                IsThreeState="True"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource DatagridCheckboxStyle}"
                                                Foreground="#70babc"
                                                ToolTip="Select / deselect all"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource DatagridCheckboxStyle}"
                                                Foreground="#70babc"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- DWG File Name -->
                                <DataGridTextColumn
                                    Header="DWG Fail"
                                    Binding="{Binding FileName}"
                                    Width="260"
                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="6,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Floor Plan View ComboBox -->
                                <DataGridTemplateColumn Header="Floor Plan Vaade" Width="*" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox
                                                ItemsSource="{Binding DataContext.AvailableViews, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                SelectedItem="{Binding SelectedView, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                DisplayMemberPath="Name"
                                                Style="{StaticResource DarkThemeComboBox}"
                                                Margin="4,2"
                                                VerticalAlignment="Center"
                                                FontSize="12"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Loading overlay -->
                    <Grid Grid.Row="2"
                          Visibility="{Binding IsLinking, Converter={StaticResource BoolToVisibilityConverter}}"
                          Background="#AA1F1F1F"
                          Panel.ZIndex="10">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar
                                IsIndeterminate="True"
                                Width="220" Height="4"
                                Foreground="#70babc"
                                Background="Transparent"
                                BorderThickness="0"/>
                            <TextBlock
                                Text="Linkimine…"
                                HorizontalAlignment="Center"
                                Foreground="{DynamicResource ForegroundBrush}"
                                FontSize="13"
                                Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Action row -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Select All"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Command="{Binding SelectAllCommand}"
                                Width="90" Height="32" FontSize="12"
                                Margin="0,0,6,0"/>
                        <Button Grid.Column="1"
                                Content="Clear All"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Command="{Binding DeselectAllCommand}"
                                Width="90" Height="32" FontSize="12"
                                Margin="0"/>
                        <Button Grid.Column="3"
                                Content="{Binding LinkButtonLabel}"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Command="{Binding LinkSelectedCommand}"
                                Width="110" Height="32" FontSize="12"
                                Margin="0,0,6,0"/>
                        <Button Grid.Column="4"
                                Content="Cancel"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="80" Height="32" FontSize="12"
                                Margin="0"
                                Click="Cancel_Click"/>
                    </Grid>
                </Grid>

                <!-- Status bar -->
                <Border
                    Grid.Row="2"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="14,0">
                    <TextBlock
                        Text="{Binding StatusMessage}"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{DynamicResource IconForegroundBrush}"
                        TextTrimming="CharacterEllipsis"/>
                </Border>

            </Grid>
        </Border>

        <!-- Resize handles -->
        <Border x:Name="LeftEdge"          Width="5"  HorizontalAlignment="Left"   Margin="0,10,0,10" Background="Transparent" Cursor="SizeWE"    MouseEnter="LeftEdge_MouseEnter"          MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="LeftEdge_MouseLeftButtonDown"/>
        <Border x:Name="RightEdge"         Width="5"  HorizontalAlignment="Right"  Margin="0,10,0,10" Background="Transparent" Cursor="SizeWE"    MouseEnter="RightEdge_MouseEnter"         MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="RightEdge_MouseLeftButtonDown"/>
        <Border x:Name="BottomEdge"        Height="5" VerticalAlignment="Bottom"   Margin="10,0,10,0" Background="Transparent" Cursor="SizeNS"    MouseEnter="BottomEdge_MouseEnter"        MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomEdge_MouseLeftButtonDown"/>
        <Border x:Name="BottomLeftCorner"  Width="10" Height="10" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNESW" MouseEnter="BottomLeftCorner_MouseEnter"  MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomLeftCorner_MouseLeftButtonDown"/>
        <Border x:Name="BottomRightCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNWSE" MouseEnter="BottomRightCorner_MouseEnter" MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomRightCorner_MouseLeftButtonDown"/>
    </Grid>
</Window>
