<Window
    x:Class="ProjectSetup.UI.ProjectSetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="clr-namespace:ProjectSetup.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Project Setup"
    Width="780"
    Height="640"
    MinWidth="560"
    MinHeight="460"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove"
    PreviewKeyDown="Window_PreviewKeyDown"
    PreviewKeyUp="Window_PreviewKeyUp"
    mc:Ignorable="av">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default theme (swapped in code-behind based on user preference) -->
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ui:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <ui:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <ui:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>

            <!-- Tab item style matching template -->
            <Style TargetType="{x:Type TabItem}">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TabItem}">
                            <Border x:Name="Border" Padding="18,8" Margin="0,0,4,0"
                                    Background="Transparent"
                                    BorderBrush="Transparent" BorderThickness="0,0,0,2">
                                <ContentPresenter x:Name="ContentSite"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                        ContentSource="Header" RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="#70babc" />
                                    <Setter Property="Foreground" Value="#70babc" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Action card container -->
            <Style x:Key="ActionCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="16,12"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <!-- Section header label -->
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#70babc"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="2,0,0,10"/>
            </Style>

            <!-- Action item title -->
            <Style x:Key="ActionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Action item description -->
            <Style x:Key="ActionDescStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource IconForegroundBrush}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="0,3,0,0"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <!-- Info card (no run button, different accent) -->
            <Style x:Key="InfoCardStyle" TargetType="Border" BasedOn="{StaticResource ActionCardStyle}">
                <Setter Property="BorderBrush" Value="#3370babc"/>
                <Setter Property="Background" Value="#0A70babc"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Outer border (blur/glass chrome effect) -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2" />
            </Border.Effect>
        </Border>

        <!-- Main content container -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            ClipToBounds="True"
            CornerRadius="10">

            <Grid x:Name="MainContentGrid" PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />   <!-- Title bar -->
                    <RowDefinition Height="*" />    <!-- Tab content -->
                    <RowDefinition Height="28" />   <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- ── Title bar ────────────────────────────── -->
                <ui:TitleBar
                    Grid.Row="0"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded" />

                <!-- Theme toggle (top-right in title bar row) -->
                <ToggleButton
                    x:Name="ThemeToggleButton"
                    Grid.Row="0"
                    Width="30" Height="30"
                    Margin="0,0,70,0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="ToggleTheme_Click"
                    IsChecked="True"
                    ToolTip="Toggle dark / light theme">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Grid Background="Transparent">
                                <materialDesign:PackIcon
                                    x:Name="ThemeIcon"
                                    Width="18" Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource IconBrush}"
                                    Kind="WeatherNight" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="ThemeIcon" Property="Kind" Value="WeatherSunny" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <!-- ── Tab content ──────────────────────────── -->
                <TabControl
                    Grid.Row="1"
                    Margin="10,5,10,5"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    BorderThickness="0"
                    Foreground="{DynamicResource ForegroundBrush}">

                    <!-- ── Tab 1: Project Setup ───────── -->
                    <TabItem Header="Project Setup">
                        <ScrollViewer
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            Margin="0,8,0,0">
                            <StackPanel Margin="0,0,6,8">

                                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="PROJECT SETUP"/>

                                <!-- Project Information -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="ClipboardTextOutline"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Project Information"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Open the Project Information dialog to review or set project name, number, client, and other parameters."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Open" Width="72"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            Command="{Binding OpenProjectInfoCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Create Levels from Link -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="LayersTriple"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Create Levels"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Create and rename project levels from a linked model (IFC or RVT). Existing template levels are reused."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Open" Width="72"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            Command="{Binding CreateLevelsCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Browser Organization -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="SitemapOutline"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Browser Organization"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Apply the standard browser organization scheme to the project views and sheets."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Run" Width="72"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            Command="{Binding ApplyBrowserOrganizationCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Required Content Check -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="CheckboxMarkedCircleOutline"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Required Content Check"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Verify that required families and shared content are loaded into the active project."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Run" Width="72"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            Command="{Binding CheckRequiredContentCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Link IFC Files -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="LinkVariant"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Link IFC Files"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Select a folder to link all IFC files into the active project. Each model is linked and pinned automatically."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Run" Width="72"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            Command="{Binding LinkIfcFilesCommand}"/>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ── Tab 2: Maintenance ─────────── -->
                    <TabItem Header="Maintenance">
                        <ScrollViewer
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            Margin="0,8,0,0">
                            <StackPanel Margin="0,0,6,8">

                                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="MAINTENANCE"/>

                                <!-- Purge Unused -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="DeleteSweepOutline"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Purge Unused"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Open Revit's Purge Unused dialog to remove unused families, types, line styles, and other elements."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Open" Width="72"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            Command="{Binding OpenPurgeUnusedCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Model Warnings -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="AlertCircleOutline"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Model Warnings"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Count and summarize current Revit model warnings. Results are shown in the status bar below."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Run" Width="72"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            Command="{Binding ReviewWarningsCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Audit placeholder -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="ShieldCheckOutline"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Model Audit"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Run a pre-defined checklist of model quality checks (category compliance, naming conventions, etc.)."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Run" Width="72"
                                            VerticalAlignment="Center"
                                            IsEnabled="False"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            ToolTip="Coming soon"
                                            Command="{Binding RunModelAuditCommand}"/>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ── Tab 3: Transfer Standards ─── -->
                    <TabItem Header="Transfer Standards">
                        <ScrollViewer
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            Margin="0,8,0,0">
                            <StackPanel Margin="0,0,6,8">

                                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="TRANSFER PROJECT STANDARDS"/>

                                <!-- Info card -->
                                <Border Style="{StaticResource InfoCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="InformationOutline"
                                            Width="18" Height="18"
                                            VerticalAlignment="Top"
                                            Foreground="#70babc" Margin="0,1,12,0"/>
                                        <TextBlock Grid.Column="1"
                                            Foreground="{DynamicResource IconForegroundBrush}"
                                            FontSize="12" TextWrapping="Wrap"
                                            Text="Both the source project and the target project must be open in Revit. Revit will prompt you to select the source project and choose which standards to transfer."/>
                                    </Grid>
                                </Border>

                                <!-- Transfer Project Standards -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="TransferRight"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Transfer Project Standards"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Launch Revit's Transfer Project Standards dialog to copy standards from another open project into this one."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Open" Width="72"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            Command="{Binding TransferStandardsCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Copy Standards from Template (future) -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="FileSyncOutline"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Apply from Template"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Select a project template file and apply its standards (line styles, fill patterns, object styles) to the active project."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Run" Width="72"
                                            VerticalAlignment="Center"
                                            IsEnabled="False"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            ToolTip="Coming soon"
                                            Command="{Binding ApplyFromTemplateCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Copy Families from another project -->
                                <Border Style="{StaticResource ActionCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0"
                                            Kind="FamilyTree"
                                            Width="24" Height="24"
                                            VerticalAlignment="Center"
                                            Foreground="#70babc" Margin="0,0,14,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource ActionTitleStyle}" Text="Copy Families"/>
                                            <TextBlock Style="{StaticResource ActionDescStyle}"
                                                Text="Browse families from another open project and import selected ones into the active document."/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Open" Width="72"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CustomActionButtonStyle}"
                                            Command="{Binding CopyElementsCommand}"/>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>

                <!-- ── Status bar ────────────────────────────── -->
                <Border
                    Grid.Row="2"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                    <Grid Margin="12,0">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            Text="{Binding StatusMessage}"
                            TextTrimming="CharacterEllipsis"/>
                        <ProgressBar
                            HorizontalAlignment="Right"
                            Width="100" Height="3"
                            VerticalAlignment="Center"
                            IsIndeterminate="True"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- Resize edges -->
        <Border x:Name="LeftEdge" Width="5" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseEnter="LeftEdge_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="LeftEdge_MouseLeftButtonDown" />
        <Border x:Name="RightEdge" Width="9" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseEnter="RightEdge_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="RightEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomEdge" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNS" Panel.ZIndex="3000"
                MouseEnter="BottomEdge_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="BottomEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomLeftCorner" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNESW" Panel.ZIndex="3000"
                MouseEnter="BottomLeftCorner_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="BottomLeftCorner_MouseLeftButtonDown" />
        <Border x:Name="BottomRightCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNWSE" Panel.ZIndex="3000"
                MouseEnter="BottomRightCorner_MouseEnter" MouseLeave="Edge_MouseLeave"
                MouseLeftButtonDown="BottomRightCorner_MouseLeftButtonDown" />

    </Grid>
</Window>