<Window
    x:Class="ProjectSetup.UI.PlaceReeperWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:ProjectSetup.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Paigalda Reeper"
    Width="660"
    Height="480"
    MinWidth="500"
    MinHeight="360"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ui:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#70babc"/>
                <Setter Property="FontSize"   Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="2,0,0,10"/>
            </Style>

            <!-- Discipline toggle button style -->
            <Style x:Key="DisciplineRadioStyle" TargetType="RadioButton">
                <Setter Property="Foreground"             Value="{DynamicResource ForegroundBrush}"/>
                <Setter Property="FontSize"               Value="13"/>
                <Setter Property="FontWeight"             Value="SemiBold"/>
                <Setter Property="Cursor"                 Value="Hand"/>
                <Setter Property="FocusVisualStyle"       Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd"
                                    Padding="18,5"
                                    CornerRadius="4"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background"    Value="#2070babc"/>
                                    <Setter TargetName="Bd" Property="BorderBrush"   Value="#70babc"/>
                                    <Setter Property="Foreground"                    Value="#70babc"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"    Value="#1470babc"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Glass chrome border -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2"/>
            </Border.Effect>
        </Border>

        <!-- Main content -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            ClipToBounds="True"
            CornerRadius="10">

            <Grid PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>    <!-- Title bar -->
                    <RowDefinition Height="*"/>     <!-- Content -->
                    <RowDefinition Height="28"/>    <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <ui:TitleBar
                    Grid.Row="0"
                    IsMinimizeVisible="False"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded"/>

                <!-- Content -->
                <Grid Grid.Row="1" Margin="14,10,14,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Section header -->
                        <RowDefinition Height="Auto"/>   <!-- Discipline picker -->
                        <RowDefinition Height="10"/>     <!-- Spacer -->
                        <RowDefinition Height="*"/>      <!-- DataGrid -->
                        <RowDefinition Height="10"/>     <!-- Spacer -->
                        <RowDefinition Height="Auto"/>   <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Section header -->
                    <TextBlock Grid.Row="0"
                               Style="{StaticResource SectionHeaderStyle}"
                               Text="PAIGALDA REEPER"/>

                    <!-- EL / EN discipline selection -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBlock Text="Distsipliin:"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <RadioButton Content="EL"
                                     Style="{StaticResource DisciplineRadioStyle}"
                                     IsChecked="{Binding IsEL}"
                                     GroupName="Discipline"/>
                        <RadioButton Content="EN"
                                     Style="{StaticResource DisciplineRadioStyle}"
                                     IsChecked="{Binding IsEN}"
                                     GroupName="Discipline"
                                     Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Results DataGrid -->
                    <Border Grid.Row="3"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            ClipToBounds="True">
                        <DataGrid
                            ItemsSource="{Binding FoundItems}"
                            SelectedItem="{Binding SelectedItem}"
                            Background="{DynamicResource PrimaryBackgroundBrush}"
                            Style="{StaticResource CustomDataGridStyle}"
                            ColumnHeaderStyle="{StaticResource CustomDataGridColumnHeaderStyle}"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            IsReadOnly="True"
                            SelectionMode="Single"
                            SelectionUnit="FullRow"
                            AlternationCount="2"
                            RowHeaderWidth="0"
                            BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Header="Lingitud mudel"
                                    Binding="{Binding LinkTitle}"
                                    Width="175"
                                    CellStyle="{StaticResource CustomDataGridCellStyle}"/>
                                <DataGridTextColumn
                                    Header="Element"
                                    Binding="{Binding DisplayName}"
                                    Width="*"
                                    CellStyle="{StaticResource CustomDataGridCellStyle}"/>
                                <DataGridTextColumn
                                    Header="X,Y,Z"
                                    Binding="{Binding SizeDisplay}"
                                    Width="88"
                                    CellStyle="{StaticResource CustomDataGridCellStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Action buttons -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="1"
                            Content="Otsi"
                            Style="{StaticResource CustomActionButtonStyle}"
                            Command="{Binding SearchCommand}"
                            Width="90" Height="32" FontSize="12"/>
                        <Button
                            Grid.Column="3"
                            Content="Paigalda"
                            Style="{StaticResource CustomActionButtonStyle}"
                            Command="{Binding PlaceCommand}"
                            Width="90" Height="32" FontSize="12"/>
                    </Grid>
                </Grid>

                <!-- Status bar -->
                <Border
                    Grid.Row="2"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="14,0">
                    <Grid>
                        <TextBlock
                            Text="{Binding StatusMessage}"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            TextTrimming="CharacterEllipsis"/>
                        <ProgressBar
                            HorizontalAlignment="Right"
                            Width="90" Height="3"
                            VerticalAlignment="Center"
                            IsIndeterminate="True"
                            Foreground="#70babc"
                            Background="Transparent"
                            BorderThickness="0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- Resize handles -->
        <Border x:Name="LeftEdge"          Width="5"  HorizontalAlignment="Left"   Margin="0,10,0,10" Background="Transparent" Cursor="SizeWE"    MouseEnter="LeftEdge_MouseEnter"          MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="LeftEdge_MouseLeftButtonDown"/>
        <Border x:Name="RightEdge"         Width="5"  HorizontalAlignment="Right"  Margin="0,10,0,10" Background="Transparent" Cursor="SizeWE"    MouseEnter="RightEdge_MouseEnter"         MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="RightEdge_MouseLeftButtonDown"/>
        <Border x:Name="BottomEdge"        Height="5" VerticalAlignment="Bottom"   Margin="10,0,10,0" Background="Transparent" Cursor="SizeNS"    MouseEnter="BottomEdge_MouseEnter"        MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomEdge_MouseLeftButtonDown"/>
        <Border x:Name="BottomLeftCorner"  Width="10" Height="10" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNESW" MouseEnter="BottomLeftCorner_MouseEnter"  MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomLeftCorner_MouseLeftButtonDown"/>
        <Border x:Name="BottomRightCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNWSE" MouseEnter="BottomRightCorner_MouseEnter" MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomRightCorner_MouseLeftButtonDown"/>

    </Grid>
</Window>
