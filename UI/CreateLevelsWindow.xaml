<Window
    x:Class="ProjectSetup.UI.CreateLevelsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:ProjectSetup.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Loo tasandid lingist"
    Width="680"
    Height="500"
    MinWidth="500"
    MinHeight="380"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ProjectSetup;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ui:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#70babc"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="2,0,0,10"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Outer border chrome -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2"/>
            </Border.Effect>
        </Border>

        <!-- Main content container -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            ClipToBounds="True"
            CornerRadius="10">

            <Grid PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>  <!-- Title bar -->
                    <RowDefinition Height="*"/>   <!-- Content -->
                    <RowDefinition Height="28"/>  <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <ui:TitleBar
                    Grid.Row="0"
                    IsMinimizeVisible="False"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded"/>

                <!-- Main content -->
                <Grid Grid.Row="1" Margin="14,10,14,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header -->
                        <RowDefinition Height="Auto"/>  <!-- Link selector -->
                        <RowDefinition Height="10"/>    <!-- Spacer -->
                        <RowDefinition Height="*"/>     <!-- Preview grid -->
                        <RowDefinition Height="10"/>    <!-- Spacer -->
                        <RowDefinition Height="Auto"/>  <!-- Apply button -->
                    </Grid.RowDefinitions>

                    <!-- Section header -->
                    <TextBlock Grid.Row="0"
                               Style="{StaticResource SectionHeaderStyle}"
                               Text="LOO TASANDID LINGITUD MUDELIST"/>

                    <!-- Link selector -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="Lingitud mudel:"
                            Foreground="{DynamicResource ForegroundBrush}"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{Binding LinkedModels}"
                            SelectedItem="{Binding SelectedLink}"
                            Style="{StaticResource DarkThemeComboBox}"
                            FontSize="13"
                            Height="32"/>
                        <Button
                            Grid.Column="2"
                            Content="Uuenda"
                            Style="{StaticResource CustomActionButtonStyle}"
                            Command="{Binding RefreshLinksCommand}"
                            Width="72" Height="32"
                            FontSize="12"
                            Margin="8,0,0,0"
                            ToolTip="Uuenda lingitud mudelite nimekirja"/>
                    </Grid>

                    <!-- Preview data grid -->
                    <Border Grid.Row="3"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            ClipToBounds="True">
                        <DataGrid
                            x:Name="LevelsGrid"
                            ItemsSource="{Binding PreviewItems}"
                            Background="{DynamicResource PrimaryBackgroundBrush}"
                            Style="{StaticResource CustomDataGridStyle}"
                            ColumnHeaderStyle="{StaticResource CustomDataGridColumnHeaderStyle}"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            IsReadOnly="True"
                            SelectionMode="Single"
                            SelectionUnit="FullRow"
                            AlternationCount="2"
                            RowHeaderWidth="0"
                            BorderThickness="0">

                            <DataGrid.Columns>

                                <!-- Level name -->
                                <DataGridTextColumn
                                    Header="Tasandi nimi"
                                    Binding="{Binding Name}"
                                    Width="*"
                                    CellStyle="{StaticResource CustomDataGridCellStyle}"/>

                                <!-- Elevation -->
                                <DataGridTextColumn
                                    Header="Kõrgus"
                                    Binding="{Binding ElevationDisplay}"
                                    Width="110"
                                    CellStyle="{StaticResource CustomDataGridCellStyle}"/>

                                <!-- Action -->
                                <DataGridTemplateColumn
                                    Header="Toiming"
                                    Width="150"
                                    CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                CornerRadius="4"
                                                Padding="6,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Margin="4,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ActionDisplay}" Value="Nimeta ümber">
                                                                <Setter Property="Background" Value="#22448866"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionDisplay}" Value="Loo uus">
                                                                <Setter Property="Background" Value="#22307ab8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionDisplay}" Value="Kustuta">
                                                                <Setter Property="Background" Value="#22884444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    Text="{Binding ActionDisplay}"
                                                    FontSize="11"
                                                    VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ActionDisplay}" Value="Nimeta ümber">
                                                                    <Setter Property="Foreground" Value="#88dd88"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ActionDisplay}" Value="Loo uus">
                                                                    <Setter Property="Foreground" Value="#88aaff"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ActionDisplay}" Value="Kustuta">
                                                                    <Setter Property="Foreground" Value="#ff8888"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Apply button -->
                    <Button
                        Grid.Row="5"
                        Content="Rakenda"
                        Style="{StaticResource CustomActionButtonStyle}"
                        Command="{Binding ApplyCommand}"
                        Width="120" Height="34"
                        HorizontalAlignment="Right"
                        FontSize="13"/>

                </Grid>

                <!-- Status bar -->
                <Border
                    Grid.Row="2"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                    <Grid Margin="12,0">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            Text="{Binding StatusMessage}"
                            TextTrimming="CharacterEllipsis"/>
                        <ProgressBar
                            HorizontalAlignment="Right"
                            Width="100" Height="3"
                            VerticalAlignment="Center"
                            IsIndeterminate="True"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Resize edges -->
        <Border x:Name="LeftEdge"   Width="4" HorizontalAlignment="Left"   Margin="0,10"   Background="Transparent" Cursor="SizeWE"   MouseEnter="Edge_MouseEnter" MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="LeftEdge_MouseLeftButtonDown"/>
        <Border x:Name="RightEdge"  Width="4" HorizontalAlignment="Right"  Margin="0,10"   Background="Transparent" Cursor="SizeWE"   MouseEnter="Edge_MouseEnter" MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="RightEdge_MouseLeftButtonDown"/>
        <Border x:Name="BottomEdge" Height="4" VerticalAlignment="Bottom"  Margin="10,0"   Background="Transparent" Cursor="SizeNS"   MouseEnter="Edge_MouseEnter" MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomEdge_MouseLeftButtonDown"/>
        <Border x:Name="BottomLeft"  Width="10" Height="10" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNESW" MouseEnter="Edge_MouseEnter" MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomLeftCorner_MouseLeftButtonDown"/>
        <Border x:Name="BottomRight" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNWSE" MouseEnter="Edge_MouseEnter" MouseLeave="Edge_MouseLeave" MouseLeftButtonDown="BottomRightCorner_MouseLeftButtonDown"/>

    </Grid>
</Window>
